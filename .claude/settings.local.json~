{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npm install)",
      "Bash(git commit:*)",
      "Bash(gh repo create:*)",
      "Bash(gh auth:*)",
      "Bash(git remote set-url:*)",
      "Bash(git push:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"\\(.tool_input.command) - \\(.tool_input.description // \"No description\")\"' >> ~/.claude/bash-command-log.txt"
          }
        ]
      }
    ]
  }
}