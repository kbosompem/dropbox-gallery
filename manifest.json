{
  "manifest_version": 3,
  "name": "Dropbox Gallery Viewer",
  "version": "1.0.0",
  "description": "Beautiful gallery view for Dropbox image folders with favoriting",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.dropbox.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.dropbox.com/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["gallery.html", "gallery.js"],
      "matches": ["https://www.dropbox.com/*"]
    }
  ]
}